export HOMEPATH="\\Users\\jt\\WorkBuddy\\Claw"

BIN="C:/Users/jt/.workbuddy/binaries/node/workspace/node_modules/@larksuite/cli/bin/lark-cli.exe"
exec "$BIN" "$@"
